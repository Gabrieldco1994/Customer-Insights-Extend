table crfc2_journeychannelcost
	lineageTag: d1b0a394-e73a-4029-9daf-47428800d02a
	sourceLineageTag: [dbo].[crfc2_journeychannelcost]

	/// Canal tratado
	measure 'Channel Name' = ```
			
			SWITCH(
			    SELECTEDVALUE('crfc2_journeychannelcost'[crfc2_new_channel]),
			    508510000, "Email",
			    508510001, "SMS",
			    508510002, "Whatsapp",
			    508510003, "Social",
			    508510004, "Push",
			    508510005, "Voice",
			    "Outro"
			)
			
			```
		lineageTag: 6d4575cf-2ed0-4a5f-a49d-40779c79894a

		changedProperty = Name

		changedProperty = Description

