table msdynmkt_journey
	lineageTag: effcab76-c53c-4ee8-b1e3-d3d9cec7ae82
	sourceLineageTag: [dbo].[msdynmkt_journey]

	measure 'Journey Fix Cost' = SUM(msdynmkt_journey[crfc2_custosfixos])
		formatString: R$ #,##0.00
		displayFolder: Custos

	measure 'Journey Total Cost' = SUM(msdynmkt_journey[crfc2_custototaldajornada])
		formatString: R$ #,##0.00
		displayFolder: Custos

	measure 'Total Interactions' = [Total Opened Email] + [Total Sent Email] + [Total Delivered Emails] + [Total Whatsapp Msg]
		formatString: #,##0
		displayFolder: Interações

	measure 'Cost of Interaction' = DIVIDE([Journey Total Cost], [Total Interactions])
		formatString: R$ #,##0.00
		displayFolder: Custos

	measure 'Cost per Lead' = DIVIDE(SUM(msdynmkt_journey[crfc2_custototaldajornada]), [leads generated by marketing], 0)
		formatString: R$ #,##0.00
		displayFolder: Custos

	measure 'ROI Value' = [Won Revenue] - [Journey Total Cost]
		formatString: R$ #,##0.00
		displayFolder: ROI

	measure 'ROI %' = DIVIDE([Won Revenue] - [Journey Total Cost], [Journey Total Cost])
		formatString: 0.00%
		displayFolder: ROI

	measure 'ROI Geral %' = DIVIDE([Won Revenue] - [Journey Total Cost], [Journey Total Cost])
		formatString: 0.00%
		displayFolder: ROI

