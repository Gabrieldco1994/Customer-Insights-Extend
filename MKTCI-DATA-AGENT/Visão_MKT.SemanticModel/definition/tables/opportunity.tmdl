table opportunity
	lineageTag: 2c45c815-1987-45e4-a6f5-3240db5396c2
	sourceLineageTag: [dbo].[opportunity]

	measure 'Opp Count' = ```
			
			DISTINCTCOUNT(Opportunity[opportunityid]) 
			```
		formatString: 0
		lineageTag: b3ba1c48-9abd-42b0-a2a0-59f0ec9337e8

		changedProperty = Name

	measure 'Estimated Revenue' =
			
			SUM(Opportunity[estimatedvalue])
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		lineageTag: f8c80ac6-1955-40e9-a308-bfc2310b569e

		changedProperty = Name

		changedProperty = FormatString

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'Won Revenue' =
			
			CALCULATE(
			    SUM(Opportunity[actualvalue]),
			    Opportunity[statecode] = 1
			)
		formatString: "R$"\ #,0.###############;-"R$"\ #,0.###############;"R$"\ #,0.###############
		lineageTag: 21cadcdd-37b4-4b15-b22e-229adb527e8d

		changedProperty = Name

		changedProperty = FormatString

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

